// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(uuid()) 
  name String
  email String @unique
  isSubscribed Boolean
  clerkId String @unique
  links Pagelink[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pagelink{
id String @id @default(uuid())
linkPagename String
pageUrl String @unique
displayName String
bio String?
avatar String?
bodyBgImage String?
profileBgImage String?
music String?
musicVolume Int?
linkBgImage String?
customTheme Json
ownerUsername String
userlinks UserLink[]
creator User @relation(fields: [ownerId],references: [clerkId],onDelete: Cascade)
ownerId String
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}

model UserLink{
  id String @id @default(uuid())
  name String
  url String
  pageId String
  totalClicks Int @default(0)
  page Pagelink @relation(fields: [pageId],references: [id],onDelete: Cascade)
}

